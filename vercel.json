{
  "version": 2,
  "outputDirectory": "public",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/app.py"
    },
    {
      "src": "/mvp",
      "dest": "/index.html"
    },
    {
      "src": "/(.*\\.(jsx|js|css|png|jpg|svg|ico|webp))",
      "dest": "/$1"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}
