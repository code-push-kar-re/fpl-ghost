{
  "version": 2,
  "installCommand": "pip install -r requirements-vercel.txt",
  "buildCommand": "echo 'static site, no build step'",
  "outputDirectory": "public",
  "functions": {
    "api/**/*.py": {
      "runtime": "python3.12",
      "maxDuration": 15
    }
  },
  "routes": [
    {
      "src": "/api/rival-squad/([^/]+)",
      "dest": "/api/rival-squad/[id].py?id=$1"
    },
    {
      "src": "/api/league/([^/]+)/rivals",
      "dest": "/api/league/[fpl_id]/rivals.py?fpl_id=$1"
    },
    {
      "src": "/api/onboard",
      "dest": "/api/onboard.py"
    },
    {
      "src": "/mvp",
      "dest": "/index.html"
    },
    {
      "src": "/(.*\\.(jsx|js|css|png|jpg|svg|ico|webp))",
      "dest": "/$1"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}
